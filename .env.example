# Server-only. Never prefix this value with NEXT_PUBLIC_.
DRILLR_API_KEY=drl_replace_me

# Optional overrides.
DRILLR_API_BASE_URL=https://gateway.drillr.ai
SEC_USER_AGENT=material-event-radar/0.1 your-email@example.com
EVENT_CACHE_TTL_SECONDS=3600
SEC_METADATA_CACHE_TTL_SECONDS=604800
PUBLIC_MAX_FILINGS=100
PUBLIC_MAX_RSS_ITEMS=50
PUBLIC_RATE_LIMIT_PER_MINUTE=20
PUBLIC_RATE_LIMIT_PER_DAY=200

# Hosted deployments serve rolling 1/7/30-day windows ending on the latest
# complete weekday. Set true only when a self-hosted instance should accept
# arbitrary historical dates using its own server-side API key.
RADAR_ALLOW_HISTORICAL_DATES=false

# Set to fixture to use the recorded 2026-07-13 validation sample without an API key.
RADAR_DATA_MODE=live
